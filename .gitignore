# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Auto-generados por Flutter en cada `pub get` (incluyendo cuando
# cambia algo en plugins). No deben estar trackeados — se regeneran
# en cada máquina y dan conflictos al cambiar de branch.
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake
macos/Flutter/GeneratedPluginRegistrant.swift

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Mensajes de commit temporales (creados a mano para usar con git commit -F)
commit_msg.txt
commit_msg*.txt

# State directory de Claude Code (worktrees temporales del agent,
# session state, etc). 100% local de la maquina, no deberia trackearse.
# Excepción: settings.json del proyecto SÍ se trackea — define el
# comportamiento del agent (allowlist de permisos, hooks) y queremos
# que sea consistente entre PCs (Santiago alterna casa/oficina).
# Usar `.claude/*` (no `.claude/`) para que git escanee adentro y
# aplique el `!.claude/settings.json` siguiente.
.claude/*
!.claude/settings.json

# Buffer local del SDK nativo de Sentry — guarda eventos pendientes
# de envío antes de transmitirlos al server. Local de la PC, no
# debería trackearse.
.sentry-native/

# Entorno y Seguridad Coopertrans Móvil
serviceAccountKey.json
*.jks
*.p12
*.key
.env
secrets.json
!secrets.example.json