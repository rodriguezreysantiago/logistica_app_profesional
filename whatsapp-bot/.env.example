# Copiar a `.env` y completar con valores reales (.env está en gitignore).

# Ruta absoluta o relativa al service account key de Firebase.
# El proyecto principal ya tiene uno en `../serviceAccountKey.json`
# (raíz del repo). Si querés, copialo al lado de este package.json y
# usa "./serviceAccountKey.json" para no depender del path padre.
FIREBASE_CREDENTIALS_PATH=../serviceAccountKey.json

# ID del proyecto Firebase. Útil si el service account no lo expone.
FIREBASE_PROJECT_ID=logisticaapp-e539a

# Bucket de Firebase Storage (donde el bot sube las fotos que mandan
# los choferes en la Fase 3). Default: `<projectId>.appspot.com`
# (legacy). Si tu proyecto se creó después de Oct 2024, podría ser
# `<projectId>.firebasestorage.app` — chequealo en la consola de
# Firebase si las subidas fallan.
# FIREBASE_STORAGE_BUCKET=logisticaapp-e539a.appspot.com

# ─── Comportamiento humano del bot (anti-baneo) ───
# Ventana de envío: SOLO lunes a viernes, en estas horas.
# La zona horaria es CRÍTICA — no usamos la del server (puede ser UTC
# o cambiar). Forzamos Buenos Aires con WORKING_TIMEZONE.
# Skip fin de semana es hardcodeado (mandar avisos los sábados/domingos
# es señal obvia de bot).
WORKING_HOURS_START=8
WORKING_HOURS_END=20
WORKING_TIMEZONE=America/Argentina/Buenos_Aires

# Delay aleatorio entre mensajes — uniformemente entre estos extremos.
# 15-60 segundos es conservador pero seguro; subir si querés más cautela.
DELAY_MIN_MS=15000
DELAY_MAX_MS=60000

# Cantidad máxima de mensajes por hora. Si la cola tiene más, los
# distribuye en la siguiente hora. Mantener bajo.
MAX_MESSAGES_PER_HOUR=30

# ─── Reintentos automáticos ───
# Cuando un envío falla por un error TRANSITORIO (timeout, red, sesión
# WA caída), el bot lo reintenta con backoff exponencial en lugar de
# marcarlo como ERROR definitivo. Errores DEFINITIVOS (teléfono
# inválido, número sin WhatsApp) van directo a ERROR — no se reintentan.
#
# MAX_RETRIES: cantidad máxima de reintentos transitorios antes de
# escalar a ERROR. Después del MAX, el doc queda en ERROR aunque el
# error siga siendo transitorio.
#
# RETRY_BACKOFF_SEC: lista CSV de segundos a esperar entre intentos.
# Default "30,120,600" = 30s, 2 min, 10 min. Si la lista tiene menos
# items que MAX_RETRIES, el último valor se reusa.
MAX_RETRIES=3
RETRY_BACKOFF_SEC=30,120,600

# ─── Watchdog del cliente WhatsApp ───
# Bug conocido: a veces después de `authenticated` el evento `ready`
# nunca llega (A/B testing de WhatsApp del lado servidor). Para que el
# bot no quede co