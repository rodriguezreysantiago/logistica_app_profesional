# Copiar a `.env` y completar con valores reales (.env está en gitignore).

# Ruta absoluta o relativa al service account key de Firebase.
# El proyecto principal ya tiene uno en `../serviceAccountKey.json`
# (raíz del repo). Si querés, copialo al lado de este package.json y
# usa "./serviceAccountKey.json" para no depender del path padre.
FIREBASE_CREDENTIALS_PATH=../serviceAccountKey.json

# ID del proyecto Firebase. Útil si el service account no lo expone.
FIREBASE_PROJECT_ID=logisticaapp-e539a

# Bucket de Firebase Storage (donde el bot sube las fotos que mandan
# los choferes en la Fase 3). Default: `<projectId>.appspot.com`
# (legacy). Si tu proyecto se creó después de Oct 2024, podría ser
# `<projectId>.firebasestorage.app` — chequealo en la consola de
# Firebase si las subidas fallan.
# FIREBASE_STORAGE_BUCKET=logisticaapp-e539a.appspot.com

# ─── Comportamiento humano del bot (anti-baneo) ───
# Ventana de envío: SOLO lunes a viernes, en estas horas.
# La zona horaria es CRÍTICA — no usamos la del server (puede ser UTC
# o cambiar). Forzamos Buenos Aires con WORKING_TIMEZONE.
# Skip fin de semana es hardcodeado (mandar avisos los sábados/domingos
# es señal obvia de bot).
WORKING_HOURS_START=8
WORKING_HOURS_END=20
WORKING_TIMEZONE=America/Argentina/Buenos_Aires

# Delay aleatorio entre mensajes — uniformemente entre estos extremos.
# 15-60 segundos es conservador pero seguro; subir si querés más cautela.
DELAY_MIN_MS=15000
DELAY_MAX_MS=60000

# Cantidad máxima de mensajes por hora. Si la cola tiene más, los
# distribuye en la siguiente hora. Mantener bajo.
MAX_MESSAGES_PER_HOUR=30

# ─── Reintentos automáticos ───
# Cuando un envío falla por un error TRANSITORIO (timeout, red, sesión
# WA caída), el bot lo reintenta con backoff exponencial en lugar de
# marcarlo como ERROR definitivo. Errores DEFINITIVOS (teléfono
# inválido, número sin WhatsApp) van directo a ERROR — no se reintentan.
#
# MAX_RETRIES: cantidad máxima de reintentos transitorios antes de
# escalar a ERROR. Después del MAX, el doc queda en ERROR aunque el
# error siga siendo transitorio.
#
# RETRY_BACKOFF_SEC: lista CSV de segundos a esperar entre intentos.
# Default "30,120,600" = 30s, 2 min, 10 min. Si la lista tiene menos
# items que MAX_RETRIES, el último valor se reusa.
MAX_RETRIES=3
RETRY_BACKOFF_SEC=30,120,600

# ─── Watchdog del cliente WhatsApp ───
# Bug conocido: a veces después de `authenticated` el evento `ready`
# nunca llega (A/B testing de WhatsApp del lado servidor). Para que el
# bot no quede colgado para siempre, agregamos un timeout: si en
# READY_TIMEOUT_SEC segundos no llega `ready`, mata el cliente y
# reintenta initialize() (sin reescaneo de QR — la sesión persiste).
#
# MAX_READY_TIMEOUTS reintentos seguidos antes de salir con código 1
# para que el supervisor (NSSM / Task Scheduler) reinicie limpio.
READY_TIMEOUT_SEC=90
MAX_READY_TIMEOUTS=3

# ─── Anti-baneo: throttle por chofer ───
# Cantidad máxima de avisos automáticos que el bot puede enviarle a
# UN MISMO chofer en un mismo día. Si el cron detecta que un chofer ya
# recibió N hoy, salta los siguientes hasta el día siguiente — evita
# ráfagas cuando le vencen 4 papeles juntos, lo que disparaba el
# detector de bots de WhatsApp.
MAX_AVISOS_POR_CHOFER_DIA=2

# ─── Modo dry-run ───
# Si es `true`, el bot hace TODO el flujo (cron, validaciones, marcar
# como enviado, contadores) PERO no envía mensajes reales. Loguea el
# destino y el texto en consola con prefijo [DRY-RUN]. Ideal para
# validar cambios al builder o al cron sin spammear a los choferes.
# En producción real debe quedar en `false`.
BOT_DRY_RUN=false

# ─── Comandos admin por WhatsApp ───
# Lista CSV de teléfonos admin autorizados (solo dígitos, con prefijo
# de país). Si el bot recibe un mensaje que empieza con `/` desde uno
# de estos números, lo procesa como comando (/estado, /pausar, etc).
# Mandá `/ayuda` al bot desde tu celu para ver la lista completa.
# Vacío = nadie tiene acceso por comandos (default seguro).
ADMIN_PHONES=

# ─── Cache del kill-switch ───
# El bot lee BOT_CONTROL/main cada N ms para saber si el admin lo
# pausó desde la app. TTL bajo = reacción rápida pero más lecturas a
# Firestore. 10s es un buen equilibrio.
BOT_CONTROL_CACHE_TTL_MS=10000

# ─── Avisos automáticos (Fase 2) ───
# Si es `true`, el bot corre un cron interno que cada
# CRON_INTERVAL_MINUTES escanea EMPLEADOS y VEHICULOS, calcula
# vencimientos por urgencia (30/15/7/1/0 días) y encola avisos
# automáticamente. Idempotente: cada aviso (mismo nivel + misma fecha
# de vencimiento) se manda UNA SOLA VEZ.
#
# Empezá con `false` para validar primero los envíos manuales desde
# la app. Cuando estés convencido, cambiá a `true` y reiniciá el bot.
AUTO_AVISOS_ENABLED=false
CRON_INTERVAL_MINUTES=60

# ─── Respuestas automáticas (Fase 3) ───
# Si es `true`, el bot escucha mensajes entrantes. Cuando un chofer
# responde a un aviso con foto + texto, crea automáticamente una
# solicitud de revisión en `REVISIONES` para que el admin la apruebe.
# Si la respuesta no se puede asociar con un aviso (ambigua), va a
# `RESPUESTAS_BOT_AMBIGUAS` para revisión manual.
AUTO_RESPUESTAS_ENABLED=false
