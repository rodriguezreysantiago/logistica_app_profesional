{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Logistica App (Windows)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            // Las credenciales Volvo viven en Secret Manager (Firebase
            // Functions) desde 2026-04-29. El cliente las consume via
            // la Cloud Function `volvoProxy`, así que ya no se inyecta
            // nada local con --dart-define.
            "toolArgs": [
                "-d", "windows"
            ]
        },
        {
            "name": "Logistica App (Windows) – Profile",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "profile",
            "toolArgs": [
                "-d", "windows"
            ]
        }
    ]
}
