// Firestore Security Rules — Coopertrans Móvil
//
// Modelo de auth:
//   La app usa Firebase Auth con custom tokens emitidos por la
//   Cloud Function `loginConDni`. El UID es el DNI del chofer y el
//   rol viaja como CUSTOM CLAIM en el JWT (`request.auth.token.rol`).
//   Eso permite chequear `isAdmin()` SIN tocar Firestore en cada
//   regla (ahorra una lectura por regla y por documento).
//
// Convenciones:
//   - `isSignedIn()`: usuario logueado (cualquier rol).
//   - `isAdmin()`: rol = 'ADMIN' en el custom claim.
//   - `isSelf(dni)`: el UID del JWT coincide con el dni del path.
//
// IMPORTANTE: si un admin cambia el ROL de un chofer en `EMPLEADOS`,
//   el custom claim queda desactualizado hasta el próximo login. Si
//   se necesita propagar más rápido, el cliente puede forzar
//   `await currentUser.getIdToken(true)` después de un cambio.
//
// DEPLOY:
//   firebase deploy --only firestore:rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // FUNCIONES DE PERMISOS
    // ========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.rol == 'ADMIN';
    }

    /// Mando medio: gestiona personal, flota, vencimientos, revisiones,
    /// bot. NO puede crear admins ni cambiar roles. Usar
    /// `isAdminOrSupervisor()` para reglas que ambos pueden.
    function isSupervisor() {
      return isSignedIn() && request.auth.token.rol == 'SUPERVISOR';
    }

    /// Helper combinado — la mayoría de reglas del panel admin
    /// (escritura de EMPLEADOS, VEHICULOS, REVISIONES, etc) aplican
    /// a ambos roles.
    function isAdminOrSupervisor() {
      return isAdmin() || isSupervisor();
    }

    /// Rol especializado: gomero/encargado de cubiertas. Opera SOLO
    /// el módulo Gomería (alta de cubiertas, instalación, recapado).
    function isGomeria() {
      return isSignedIn() && request.auth.token.rol == 'GOMERIA';
    }

    /// Rol especializado: Seguridad e Higiene. Monitorea conducta y
    /// eventos Volvo (alertas, eco-driving, descargas PTO, mapa).
    function isSegHigiene() {
      return isSignedIn() && request.auth.token.rol == 'SEG_HIGIENE';
    }

    /// Quiénes pueden operar el módulo Gomería: admin/supervisor +
    /// el rol especializado GOMERIA.
    function puedeOperarGomeria() {
      return isAdminOrSupervisor() || isGomeria();
    }

    /// Quiénes pueden ver los tableros Volvo (alertas, eco-driving,
    /// descargas PTO, mapa de eventos): admin/supervisor + SEG_HIGIENE.
    function puedeVerVolvoTableros() {
      return isAdminOrSupervisor() || isSegHigiene();
    }

    function isSelf(dni) {
      return isSignedIn() && request.auth.uid == dni;
    }

    // ========================================================================
    // EMPLEADOS — cada chofer ve su propio legajo; el admin ve todos
    // ========================================================================

    match /EMPLEADOS/{dni} {
      // Lectura: el dueño puede ver su legajo, admin/supervisor todos.
      allow read: if isAdminOrSupervisor() || isSelf(dni);
      // Crear y borrar: solo admin/supervisor (alta y baja).
      allow create, delete: if isAdminOrSupervisor();
      // Update: admin/supervisor sin restricción.
      // El chofer (dueño del legajo) puede actualizar SOLO los campos
      // self-service de "Mi Perfil":
      //   - ARCHIVO_PERFIL: foto de perfil (sube nueva foto y actualiza URL).
      //   - CONTRASEÑA: hash bcrypt nuevo cuando cambia su clave.
      // Cualquier otro campo (DNI, rol, vencimientos, vehículo asignado,
      // etc.) está reservado a admin/supervisor.
      allow update: if isAdminOrSupervisor()
        || (isSelf(dni)
            && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['ARCHIVO_PERFIL', 'CONTRASEÑA']));
    }

    // ========================================================================
    // VEHICULOS — cualquier logueado lee, solo admin escribe
    // ========================================================================

    match /VEHICULOS/{patente} {
      // El chofer necesita leer su unidad asignada y los papeles del
      // vehículo (RTO, Seguro). Acepta cualquier signedIn.
      allow read: if isSignedIn();
      // Alta, edición, sincronización Volvo (KM/combustible/autonomía):
      // admin o supervisor. El bot bypasea con Admin SDK.
      allow write: if isAdminOrSupervisor();
    }

    // ========================================================================
    // REVISIONES — chofer crea solicitud, admin aprueba/rechaza
    // ========================================================================

    match /REVISIONES/{doc} {
      allow read: if isSignedIn();
      // Chofer crea su propia solicitud al renovar un papel.
      // Admin/supervisor aprueban o rechazan.
      allow create: if isSignedIn();
      allow update, delete: if isAdminOrSupervisor();
    }

    // ========================================================================
    // CHECKLISTS — chofer registra, admin lee histórico
    // ========================================================================

    match /CHECKLISTS/{doc} {
      allow read: if isSignedIn();
      // El chofer crea su checklist mensual. NO debería poder editar
      // checklists pasados (auditoría inmutable).
      allow create: if isSignedIn();
      allow update, delete: if isAdminOrSupervisor();
    }

    // ========================================================================
    // AVISOS_VENCIMIENTOS — bitácora de avisos manuales del admin
    // ========================================================================

    match /AVISOS_VENCIMIENTOS/{doc} {
      // Lectura: chofer ve su propio historial; admin ve todo.
      // Por simplicidad permitimos a cualquier signedIn leer (los
      // datos no son sensibles).
      allow read: if isSignedIn();
      // Solo admin registra (lo dispara el botón "Avisar por WhatsApp").
      allow write: if isAdmin();
    }

    // ========================================================================
    // COLA_WHATSAPP — el admin encola, el bot Node.js procesa via Admin SDK
    // ========================================================================

    match /COLA_WHATSAPP/{doc} {
      // El bot bypasea con Admin SDK; las rules valen solo para clientes.
      // Admin y supervisor pueden ver/encolar/reintentar/eliminar.
      allow read, write: if isAdminOrSupervisor();
    }

    // ========================================================================
    // AUDITORIA_ACCIONES — bitácora del admin
    // ========================================================================

    match /AUDITORIA_ACCIONES/{doc} {
      // Solo admin la lee (auditoría sensible). La escritura va
      // EXCLUSIVAMENTE por la Cloud Function callable `auditLogWrite`,
      // que valida server-side el rol (ADMIN universal, SUPERVISOR
      // restringido a una whitelist reducida de acciones — asignaciones
      // y gomería) y toma `admin_dni` (== actor real, sea ADMIN o
      // SUPERVISOR) del token, no del cliente. Eso evita que un actor
      // con la consola abierta forje entradas falsas de bitácora.
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========================================================================
    // TELEMETRIA_HISTORICO — snapshots Volvo para reporte de consumo
    // ========================================================================

    match /TELEMETRIA_HISTORICO/{doc=**} {
      // Solo escribe la scheduled function `telemetriaSnapshotScheduled`
      // (cada 6 horas) vía Admin SDK. La app cliente NO escribe acá
      // desde 2026-04-29 — el cliente solo lee para mostrar el reporte
      // de consumo.
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========================================================================
    // STATS — agregaciones server-side para el dashboard
    // ========================================================================
    //
    // Solo escribe la scheduled function `recomputeDashboardStats`
    // (cada 5 min) vía Admin SDK. El cliente lee `STATS/dashboard` para
    // pintar los KPIs (~177 docs antes, 1 doc ahora). Lectura abierta a
    // admin + supervisor (mismos roles que ven el panel).
    match /STATS/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // ========================================================================
    // AVISOS_AUTOMATICOS_HISTORICO — idempotencia del cron del bot
    // ========================================================================

    match /AVISOS_AUTOMATICOS_HISTORICO/{doc=**} {
      // Solo el bot escribe (Admin SDK). La app solo lee.
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========================================================================
    // RESPUESTAS_BOT_AMBIGUAS — bandeja de respuestas del bot
    // ========================================================================

    match /RESPUESTAS_BOT_AMBIGUAS/{doc=**} {
      // El bot las CREA via Admin SDK (bypassea las rules).
      // Admin/Supervisor las DESCARTAN o las CONVIERTEN en revision
      // -- ambas operaciones implican delete del doc ambiguo.
      // No hay caso de uso valido de create/update desde el cliente.
      allow read: if isAdminOrSupervisor();
      allow delete: if isAdminOrSupervisor();
      allow create, update: if false;
    }

    // ========================================================================
    // BOT_HEALTH — heartbeat del bot Node.js
    // ========================================================================
    // El bot escribe `BOT_HEALTH/main` cada ~60s (vía Admin SDK) con
    // estado del cliente WA, cola, último ciclo del cron, errores
    // recientes, etc. La pantalla "Estado del Bot" del admin lo lee en
    // vivo. Como el doc tiene info operacional (cantidad de mensajes,
    // patrón de errores) y el contenido podría exponer detalles internos,
    // restringimos lectura a ADMIN.

    match /BOT_HEALTH/{doc} {
      // Admin y supervisor pueden ver el estado del bot. Solo el bot
      // vía Admin SDK escribe — write:false del lado cliente.
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // BOT_EVENTOS — log de caídas/recuperaciones del bot (2026-05-08).
    // Lo popula `botHealthWatchdog` (Admin SDK). El cron `resumenBotDiario`
    // lo lee y arma resumen WhatsApp. Si en el futuro queremos mostrar
    // histórico de caídas en la pantalla "Estado del bot", admin lo lee.
    match /BOT_EVENTOS/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // ========================================================================
    // BOT_CONTROL — kill-switch del bot (pausar / reanudar desde la app)
    // ========================================================================
    // Estado simple: `pausado: bool` + metadata (quién, cuándo, motivo).
    // El bot polea este doc cada ~10s desde su src/control.js. Si está
    // pausado, salta el procesamiento de la cola y deja los docs en
    // PENDIENTE — los retoma cuando se reanude.
    //
    // Lectura: admin y supervisor (para que ambos vean el estado en la
    // pantalla 'Estado del Bot'). Escritura: solo ADMIN, porque pausar
    // detiene los envíos a choferes y debe ser una decisión deliberada
    // del responsable, no del SUPERVISOR de turno.

    match /BOT_CONTROL/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if isAdmin();
    }

    // ========================================================================
    // MANTENIMIENTOS_AVISADOS — idempotencia de notificación local
    // ========================================================================
    // El cliente Flutter (admin) escribe acá cada vez que evalúa el
    // estado de service de un tractor después de un sync Volvo. Guarda
    // `ultimo_estado` (VENCIDO / URGENTE / ...) para detectar cruces y
    // no spamear notificaciones. Es estado interno operacional —
    // bajo riesgo de manipulación. Si se "falsifica", lo único que pasa
    // es que se re-notifica o no, sin afectar datos críticos.

    match /MANTENIMIENTOS_AVISADOS/{patente} {
      allow read, write: if isAdminOrSupervisor();
    }

    // ========================================================================
    // VOLVO_ALERTAS — eventos del Vehicle Alerts API (solo Cloud Function escribe)
    // ========================================================================
    // La scheduled function `volvoAlertasPoller` corre cada 5 min y popula
    // esta colección con los eventos que devuelve la Volvo Vehicle Alerts
    // API (IDLING, DISTANCE_ALERT, OVERSPEED, PTO, TELL_TALE, ALARM, etc).
    // El docId es composite e idempotente: `{vin}_{createdMs}_{tipo}`.
    //
    // El cliente puede MARCAR alertas como atendidas (escribiendo los
    // campos `atendida`, `atendida_por`, `atendida_en`) pero no puede
    // crearlas ni borrarlas — todo create/delete pasa por Admin SDK.

    match /VOLVO_ALERTAS/{doc} {
      // Lectura y "marcar atendida" disponible para admin, supervisor
      // y el rol SEG_HIGIENE (Seguridad e Higiene).
      allow read: if puedeVerVolvoTableros();
      // Update: marcar como atendida desde el tablero. AUDITORIA_ACCIONES
      // guarda quién marcó qué.
      allow update: if puedeVerVolvoTableros();
      allow create, delete: if false;
    }

    // ========================================================================
    // SITRACK_POSICIONES — última posición conocida de cada unidad
    // ========================================================================
    // Doc id = patente. Lo escribe la scheduled function
    // `sitrackPosicionPoller` cada 5 min llamando al endpoint /v2/report
    // de Sitrack. Es snapshot, no histórico — cada poll reemplaza
    // (con merge) los campos del doc.
    //
    // El cliente Flutter solo lee (mapa flota en vivo). Toda escritura
    // pasa por la Cloud Function (Admin SDK saltea las rules), así que
    // create/update/delete desde el cliente quedan cerrados.

    match /SITRACK_POSICIONES/{patente} {
      // Mismos roles que pueden ver tableros Volvo (admin / supervisor /
      // SEG_HIGIENE). El mapa de la flota es dato sensible — ubicación
      // del personal — y no corresponde exponerlo a roles operativos.
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // JORNADAS_CHOFER — tracking de horas de manejo por chofer y día
    // ========================================================================
    // Doc id: `{dni}_{YYYY-MM-DD}`. Lo escribe el cron
    // `vigiladorJornadaChofer` cada 5 min con segundos acumulados de
    // manejo (>10 km/h), continuo actual, pausa actual y flags de
    // alertas enviadas. Resumen al jefe de Seg e Higiene a las 23:55.
    //
    // El cliente Flutter podría leer esto en el futuro para mostrar
    // un dashboard "horas del día por chofer" — por ahora solo el
    // server lo escribe. Lectura para los mismos roles que ven
    // tableros Volvo (admin/supervisor/SEG_HIGIENE).

    match /JORNADAS_CHOFER/{doc} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // META_AVISOS_NO_ID — throttle del aviso "pasá el iButton" (server-only)
    // ========================================================================
    // Doc id: dni del chofer. Guarda `last_sent_at` (server timestamp) y
    // `last_patente`. Lo escribe el cron `sitrackPosicionPoller` después
    // de encolar un aviso, y lo lee al inicio de cada ciclo para no
    // mandar otro mensaje al mismo chofer dentro de los 30 min.
    //
    // Sin esto el chofer recibiría 1 mensaje cada 5 min mientras siga
    // manejando sin pasar el iButton — spam directo + riesgo de baneo
    // de WhatsApp. Decisión Vecchi 2026-05-07.
    //
    // Solo el server (Admin SDK) accede. Cliente bloqueado.

    match /META_AVISOS_NO_ID/{doc} {
      allow read, write: if false;
    }

    // ========================================================================
    // LOGÍSTICA — catálogos para el futuro planeamiento de viajes
    // ========================================================================
    // Tres colecciones que arman el modelo de "rutas con precio":
    //   - EMPRESAS_LOGISTICA: clientes (origen/destino) + dadores de
    //     transporte (otros transportistas que nos ceden cargas).
    //   - UBICACIONES_LOGISTICA: puntos físicos de carga/descarga.
    //   - TARIFAS_LOGISTICA: ruta con precio + comisión del dador (si
    //     aplica) + tarifa al chofer.
    //
    // Acceso: admin/supervisor lee y escribe. Otros roles bloqueados —
    // los choferes no necesitan ver tarifas (es info comercial), Seg e
    // Higiene tampoco (es parte de operación, no de monitoreo).
    //
    // Soft-delete via campo `activa: bool`. Las históricas se mantienen
    // para reportes pasados. NO permitimos `delete` para preservar el
    // histórico — si el operador se equivoca con un alta, la desactiva.

    match /EMPRESAS_LOGISTICA/{doc} {
      allow read, create, update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    match /UBICACIONES_LOGISTICA/{doc} {
      allow read, create, update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    match /TARIFAS_LOGISTICA/{doc} {
      allow read, create, update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    // ========================================================================
    // VIAJES_LOGISTICA — ejecución y liquidación de viajes
    // ========================================================================
    // 1 doc por viaje real (carga → descarga). Refiere a TARIFAS_LOGISTICA
    // con snapshot. Incluye datos delicados: tarifas, comisiones,
    // adelantos, gastos, liquidación al chofer. NO se expone al chofer
    // (decisión Santiago 2026-05-09).
    //
    // Soft-delete via `activo: false`. NO permitimos `delete` para
    // preservar histórico — si el operador se equivoca, desactiva.

    match /VIAJES_LOGISTICA/{doc} {
      allow read, create, update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    // ========================================================================
    // EMPRESAS_EMPLEADORAS — Póliza ART y F.931 a nivel empresa
    // ========================================================================
    // Una entrada por empresa empleadora del personal (Vecchi Ariel,
    // Sucesión Vecchi Carlos). DocId = CUIT. Guarda el PDF + la fecha de
    // cada documento laboral que es COMÚN a todos los empleados de esa
    // razón social — la Póliza ART y el Formulario 931 son por empresa,
    // no por persona.
    //
    // Lectura: cualquier usuario autenticado, así el chofer ve los docs
    // de su empresa en MIS VENCIMIENTOS (read-only).
    // Escritura: admin/supervisor (los mismos que ya manejan personal y
    // vencimientos). NO permitimos delete — es histórico.
    match /EMPRESAS_EMPLEADORAS/{cuit} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    // ========================================================================
    // ASIGNACIONES_VEHICULO — log temporal de quién manejó qué unidad
    // ========================================================================
    // Cada doc representa el período en que un chofer manejó una patente.
    // El doc activo (vigente) tiene `hasta == null`. Cuando hay un cambio,
    // se "cierra" el activo (`hasta = now`) y se crea uno nuevo. Permite
    // responder "¿quién manejaba la patente X el día Y?" para multas
    // tardías, atribución de eventos Volvo y disputas.
    //
    // Las escrituras pasan por `AsignacionVehiculoService` desde el cliente
    // (no hay Cloud Function dedicada). Por eso las reglas validan la
    // estructura para que el admin no pueda meter basura ni reescribir
    // historial.

    match /ASIGNACIONES_VEHICULO/{doc} {
      // Lectura: admin/supervisor. El chofer no necesita ver el log.
      allow read: if isAdminOrSupervisor();

      // Crear una nueva asignación: requiere admin/supervisor + estructura
      // mínima. `hasta` debe ser null (las nuevas SIEMPRE arrancan
      // activas). `asignado_por_dni` tiene que ser quien escribe — el
      // admin no puede atribuir el cambio a otro.
      allow create: if isAdminOrSupervisor()
        && request.resource.data.asignado_por_dni == request.auth.uid
        && request.resource.data.vehiculo_id is string
        && request.resource.data.chofer_dni is string
        && request.resource.data.desde is timestamp
        && request.resource.data.hasta == null;

      // Actualizar: se permite cerrar (setear `hasta`) y, opcionalmente,
      // sumar el snapshot de odómetro Sitrack al cierre (para calcular
      // km recorridos por chofer en este período). No se puede editar
      // `desde`, `chofer_dni`, `vehiculo_id`, etc — el log es inmutable
      // salvo por el cierre. Y solo si todavía estaba activa.
      allow update: if isAdminOrSupervisor()
        && resource.data.hasta == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['hasta', 'odometer_final', 'odometer_final_ts'])
        && request.resource.data.hasta is timestamp;

      // Borrar: nunca. Si hay que corregir un dato, se cierra y se
      // crea uno nuevo (audit > corrección silenciosa).
      allow delete: if false;
    }

    // ========================================================================
    // ASIGNACIONES_ENGANCHE — log temporal de qué tractor llevó qué enganche
    // ========================================================================
    // Espejo conceptual de ASIGNACIONES_VEHICULO pero para la relación
    // tractor↔enganche. Sin esto, no se puede calcular cuántos km recorrió
    // una cubierta de enganche (la cubierta está en el enganche, los km
    // los recorre el tractor — y un enganche pasa por varios tractores).
    //
    // Las escrituras pasan por `AsignacionEngancheService` desde el cliente.
    // Mismas validaciones que ASIGNACIONES_VEHICULO: estructura mínima +
    // `hasta = null` al crear + solo se permite "cerrar" (setear `hasta`).

    match /ASIGNACIONES_ENGANCHE/{doc} {
      // Lectura: admin/supervisor (incluye supervisor de gomería).
      // El chofer no necesita ver el log.
      allow read: if isAdminOrSupervisor();

      // Crear una nueva asignación: requiere admin/supervisor + estructura
      // mínima + `hasta == null` (nuevas siempre arrancan activas).
      allow create: if isAdminOrSupervisor()
        && request.resource.data.asignado_por_dni == request.auth.uid
        && request.resource.data.enganche_id is string
        && request.resource.data.tractor_id is string
        && request.resource.data.desde is timestamp
        && request.resource.data.hasta == null;

      // Actualizar: se permite cerrar (`hasta`) y, opcionalmente, sumar
      // el snapshot de odómetro Sitrack del tractor al cierre (para
      // calcular km del tractor durante el período del enganche, base
      // del cálculo de km cubiertas Fase 2 Gomería). El log es
      // inmutable en todo lo demás.
      allow update: if isAdminOrSupervisor()
        && resource.data.hasta == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['hasta', 'odometer_final', 'odometer_final_ts'])
        && request.resource.data.hasta is timestamp;

      // Borrar: nunca.
      allow delete: if false;
    }

    // ========================================================================
    // CUBIERTAS_MARCAS — catálogo de marcas de cubiertas (ABM admin)
    // ========================================================================
    // Soft-delete con `activo: false` para no romper referencias históricas
    // en cubiertas/modelos ya cargados con esa marca.

    match /CUBIERTAS_MARCAS/{doc} {
      // Lectura: admin/supervisor + rol GOMERIA (operador del módulo).
      allow read: if puedeOperarGomeria();
      // Escritura: solo admin. La gomería usa lo que el admin definió.
      allow write: if isAdmin();
    }

    // ========================================================================
    // CUBIERTAS_MODELOS — catálogo de modelos (marca + modelo + medida + tipo_uso)
    // ========================================================================
    // El admin define qué modelos se manejan, sus km_vida_estimada (nueva y
    // recapada) y si son recapables. La gomería instala cubiertas de estos
    // modelos pero no edita el catálogo.

    match /CUBIERTAS_MODELOS/{doc} {
      // Lectura: admin/supervisor + GOMERIA. Escritura: solo admin.
      allow read: if puedeOperarGomeria();
      allow write: if isAdmin();
    }

    // ========================================================================
    // CUBIERTAS — inventario individual (1 doc por cubierta física)
    // ========================================================================
    // El supervisor de gomería da de alta cubiertas (al recibir nuevas del
    // proveedor) y actualiza estado/vidas/km_acumulados a través del flujo
    // de instalación/retiro/recapado.

    match /CUBIERTAS/{doc} {
      allow read: if puedeOperarGomeria();
      // Crear: el alta debe atribuirse a quien escribe (no falsificable).
      allow create: if puedeOperarGomeria()
        && request.resource.data.creado_por_dni == request.auth.uid;
      // Update / delete: admin/supervisor + GOMERIA. Las mutaciones del
      // ciclo de vida pasan por `GomeriaService` que valida estructura.
      allow update, delete: if puedeOperarGomeria();
    }

    // ========================================================================
    // CUBIERTAS_INSTALADAS — log temporal cubierta↔posición
    // ========================================================================
    // Espejo conceptual de ASIGNACIONES_VEHICULO pero para la relación
    // cubierta↔posición. La activa tiene `hasta == null`. Al retirar se
    // cierra (`hasta = now`, km_unidad_al_retirar, km_recorridos calculados).
    //
    // Las escrituras pasan por `GomeriaService` desde el cliente. Las reglas
    // validan estructura mínima al crear y bloquean ediciones arbitrarias
    // del histórico — solo se puede "cerrar" la activa.

    match /CUBIERTAS_INSTALADAS/{doc} {
      // Lectura: admin/supervisor + GOMERIA.
      allow read: if puedeOperarGomeria();

      // Crear: requiere admin/supervisor o GOMERIA + estructura mínima
      // + `hasta == null` (las nuevas siempre arrancan activas).
      // `instalado_por_dni` debe ser quien escribe.
      allow create: if puedeOperarGomeria()
        && request.resource.data.instalado_por_dni == request.auth.uid
        && request.resource.data.cubierta_id is string
        && request.resource.data.unidad_id is string
        && request.resource.data.posicion is string
        && request.resource.data.desde is timestamp
        && request.resource.data.hasta == null;

      // Actualizar: dos flujos válidos sobre la instalación activa:
      // (a) cerrar la instalación (setear `hasta`, km_*_retirar,
      //     km_recorridos, los campos de auditoría del retiro y motivo).
      // (b) registrar una lectura de control (presión / profundidad de
      //     banda) sin cerrar — `hasta` queda en null.
      // Cualquier otro cambio se rechaza para mantener el log inmutable.
      allow update: if puedeOperarGomeria()
        && resource.data.hasta == null
        && (
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['hasta', 'km_unidad_al_retirar', 'km_recorridos',
                        'retirado_por_dni', 'retirado_por_nombre',
                        'motivo_retiro'])
            && request.resource.data.hasta is timestamp)
          ||
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['ultima_presion_psi', 'ultima_profundidad_banda_mm',
                        'ultima_lectura_en', 'ultima_lectura_por_dni',
                        'ultima_lectura_por_nombre'])
            && request.resource.data.hasta == null)
        );

      // Borrar: nunca. Si hubo error, se cierra y se registra una corrección.
      allow delete: if false;
    }

    // ========================================================================
    // CUBIERTAS_POSICIONES_ACTIVAS / CUBIERTAS_ACTIVAS — locks de unicidad
    // ========================================================================
    // Docs de control transaccional para garantizar que una posición
    // de unidad no tenga 2 cubiertas instaladas al mismo tiempo y que
    // una cubierta no figure activa en 2 lugares (ver
    // `GomeriaService.instalar` para el flujo completo). El cliente
    // los crea/borra dentro de la transaction de instalar/retirar.

    match /CUBIERTAS_POSICIONES_ACTIVAS/{doc} {
      allow read: if puedeOperarGomeria();
      allow create, delete: if puedeOperarGomeria();
      // No update: si la posición cambia de cubierta hay que borrar
      // y recrear (la dos operaciones son del flujo retirar+instalar
      // o del flujo "rotar").
      allow update: if false;
    }

    match /CUBIERTAS_ACTIVAS/{doc} {
      allow read: if puedeOperarGomeria();
      allow create, delete: if puedeOperarGomeria();
      allow update: if false;
    }

    // ========================================================================
    // CUBIERTAS_PROVEEDORES — catálogo de proveedores de recapado
    // ========================================================================
    // Mismo patrón que CUBIERTAS_MARCAS pero ABM disponible para
    // supervisor también — el supervisor puede agregar un proveedor
    // nuevo on-the-fly cuando manda una cubierta a un taller que aún no
    // está en la lista. Soft-delete con `activo`.

    match /CUBIERTAS_PROVEEDORES/{doc} {
      allow read: if puedeOperarGomeria();
      allow write: if puedeOperarGomeria();
    }

    // ========================================================================
    // CUBIERTAS_RECAPADOS — eventos de envío a recapar
    // ========================================================================
    // 1 doc por envío. Se crea con `fecha_retorno = null` y `resultado = null`
    // (la cubierta queda EN_RECAPADO). Cuando vuelve, se completa con
    // `fecha_retorno`, `resultado` (RECIBIDA o DESCARTADA_POR_PROVEEDOR),
    // `costo` y `notas`. La cubierta vuelve a EN_DEPOSITO (vidas++) o
    // DESCARTADA según el resultado.

    match /CUBIERTAS_RECAPADOS/{doc} {
      allow read: if puedeOperarGomeria();

      // Crear envío a recapado: estructura mínima + en proceso (no cerrado).
      allow create: if puedeOperarGomeria()
        && request.resource.data.enviado_por_dni == request.auth.uid
        && request.resource.data.cubierta_id is string
        && request.resource.data.proveedor is string
        && request.resource.data.fecha_envio is timestamp
        && request.resource.data.fecha_retorno == null
        && request.resource.data.resultado == null;

      // Cerrar el recapado al recibir la cubierta. Se permite setear
      // `fecha_retorno`, `resultado`, `costo`, `notas` y los campos de
      // auditoría del cierre. El resto es inmutable.
      allow update: if puedeOperarGomeria()
        && resource.data.fecha_retorno == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['fecha_retorno', 'resultado', 'costo', 'notas',
                      'cerrado_por_dni', 'cerrado_por_nombre'])
        && request.resource.data.fecha_retorno is timestamp;

      // Borrar: nunca.
      allow delete: if false;
    }

    // ========================================================================
    // CUBIERTAS_CONTROLES — histórico inmutable de lecturas presión/banda
    // ========================================================================
    // Cada `registrarLectura()` del GomeriaService crea 1 doc acá Y pisa
    // los `ultima_*` de la CUBIERTAS_INSTALADAS. La verdad histórica para
    // auditoría / trending vive en esta colección — la "última" es solo
    // un atajo para la grilla.

    match /CUBIERTAS_CONTROLES/{doc} {
      allow read: if puedeOperarGomeria();

      // Crear: estructura mínima + auth.uid coincide con
      // registrado_por_dni para no permitir suplantación.
      // Al menos uno de los 2 campos de medición debe estar.
      allow create: if puedeOperarGomeria()
        && request.resource.data.registrado_por_dni == request.auth.uid
        && request.resource.data.cubierta_id is string
        && request.resource.data.instalacion_id is string
        && request.resource.data.unidad_id is string
        && request.resource.data.posicion is string
        && request.resource.data.fecha is timestamp
        && (request.resource.data.keys().hasAny(['presion_psi', 'profundidad_banda_mm']));

      // Inmutable: nunca se modifican los controles ya creados —
      // si hubo error de carga se anota una lectura nueva.
      allow update, delete: if false;
    }

    // ========================================================================
    // VOLVO_SCORES_DIARIOS — scores de eco-driving (Volvo Group Scores API)
    // ========================================================================
    // La scheduled function `volvoScoresPoller` corre 1x por día a las 04:00
    // ART y popula esta colección con el score AGREGADO POR DÍA de cada
    // vehículo (docId `{patente}_{YYYY-MM-DD}`) y el de la flota completa
    // (docId `_FLEET_{YYYY-MM-DD}`).
    //
    // Sin campos de gestión humana — son métricas calculadas por Volvo.
    // Idempotente: si el poller corre dos veces el mismo día, sobrescribe
    // los mismos campos sin pérdida.

    match /VOLVO_SCORES_DIARIOS/{doc} {
      // Lectura admin/supervisor + SEG_HIGIENE (para pantalla
      // eco-driving). Escritura: solo el poller via Admin SDK.
      allow read: if puedeVerVolvoTableros();
      allow write: if false;
    }

    // ========================================================================
    // META — estado interno de los pollers (cursor, etc.)
    // ========================================================================
    // Subcolección de docs internos del server (cursor del poller Volvo
    // Alerts, futuros cursors de otros pollers). Ningún cliente debe leer
    // ni escribir — todo pasa por Admin SDK.
    //
    // EXCEPCIÓN: `META/cubiertas_counter` lo INCREMENTA `GomeriaService`
    // desde el cliente dentro de la transaction de `crearCubierta` (para
    // generar el código `CUB-XXXX` zero-padded sin un round-trip extra a
    // una Cloud Function). Es un contador int monotónico — el peor caso
    // si un atacante lo manipula es que se "salten" números de código,
    // sin afectar integridad de datos.

    match /META/cubiertas_counter {
      allow read: if puedeOperarGomeria();
      // Create: solo si el contador arranca en 1 (primer alta del sistema).
      allow create: if puedeOperarGomeria()
        && request.resource.data.proximo == 1;
      // Update: solo +1 monotónico. No permite saltos ni decrementos —
      // un bug del cliente o un set manual no puede romper la secuencia.
      allow update: if puedeOperarGomeria()
        && request.resource.data.proximo == resource.data.proximo + 1;
      allow delete: if false;
    }

    match /META/{doc=**} {
      allow read, write: if false;
    }

    // ========================================================================
    // LOGIN_ATTEMPTS — rate limiting del login (solo Cloud Function)
    // ========================================================================
    // La function `loginConDni` escribe acá vía Admin SDK (bypasea rules).
    // Ningún cliente debe leer/escribir directo. La colección guarda
    // intentos fallidos consecutivos por DNI (clave = hash corto del DNI)
    // y un timestamp `bloqueadoHasta` que la function consulta antes de
    // verificar la contraseña.

    match /LOGIN_ATTEMPTS/{dniHash} {
      allow read, write: if false;
    }

    // ========================================================================
    // FALLBACK — todo lo demás bloqueado
    // ========================================================================
    // Si en el futuro alguien crea una colección nueva, queda
    // bloqueada por default hasta que se sume explícitamente arriba.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
