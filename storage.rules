// Firebase Storage Security Rules — Coopertrans Móvil
//
// Mismo modelo de auth que firestore.rules: Firebase Auth con custom
// tokens, UID = DNI, rol en custom claim `request.auth.token.rol`.
//
// Paths usados por la app:
//   - PERFILES/{dni}.jpg                — foto del chofer
//   - perfiles/{dni}.jpg                — variante legacy con minúsculas
//   - vehiculos/{patente}/foto.jpg      — foto de la unidad
//   - vehiculos/{patente}/{nombre}      — comprobantes RTO/Seguro/Extintores
//   - EMPLEADOS/{dni}/{nombre}          — papeles del chofer (admin reemplaza)
//   - EMPLEADOS_DOCS/                   — comprobantes (auditoría)
//   - VEHICULOS_DOCS/                   — comprobantes (auditoría)
//   - REVISIONES/                       — comprobantes que sube el chofer
//   - RESPUESTAS_BOT/{dni}_{ts}.{ext}   — fotos que llegan vía bot
//
// DEPLOY:
//   firebase deploy --only storage

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ========================================================================
    // FUNCIONES DE PERMISOS
    // ========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.rol == 'ADMIN';
    }

    function isAdminOrSupervisor() {
      return isSignedIn()
        && (request.auth.token.rol == 'ADMIN'
            || request.auth.token.rol == 'SUPERVISOR');
    }

    function isSegHigiene() {
      return isSignedIn() && request.auth.token.rol == 'SEG_HIGIENE';
    }

    // Nota auditoria 2026-05-18: pensado un helper `isEmpleadoDeEmpresa(cuit)`
    // que comparara EMPLEADOS.{uid}.CUIT_EMPLEADOR == cuit, pero ese campo
    // NO existe en los docs (EMPLEADOS.EMPRESA guarda el nombre como string,
    // no el CUIT). Backfill pendiente. Mientras tanto, EMPRESAS_EMPLEADORAS
    // pasa a admin/supervisor/seg_higiene only — los choferes pierden la
    // vista de sus pólizas en MIS VENCIMIENTOS (placeholder "consultar
    // oficina"), trade-off aceptable frente a la filtración de sueldos
    // del F.931 entre razones sociales.

    // ========================================================================
    // RESPUESTAS_BOT — solo el bot sube (Admin SDK), admin las lee
    // ========================================================================

    match /RESPUESTAS_BOT/{archivo=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========================================================================
    // PERFILES — foto del chofer
    // ========================================================================
    // Lectura: cualquier signedIn (chofer ve su perfil + admin ve todos).
    // Escritura:
    //   - Admin/supervisor: cualquier foto (alta del chofer + cambio
    //     desde gestión de personal).
    //   - Chofer: solo SU propia foto (archivo cuyo nombre arranca con
    //     su DNI/UID + extensión, ej. "12345678.jpg").
    // El path de la app es `PERFILES/{dni}.jpg`. Si algún día se usa
    // otra extensión (.png/.webp) la regex la cubre con `.\\..*`.
    //
    // Soportamos dos paths legacy + nuevo (mayúsculas/minúsculas).

    match /PERFILES/{archivo} {
      // CRITICO (auditoria 2026-05-17): antes cualquier signedIn leia
      // CUALQUIER foto de perfil — un chofer podia adivinar el DNI de
      // otro y bajar su foto. Ahora: admin/supervisor todos, chofer
      // solo SU foto (archivo arranca con su UID).
      allow read: if isAdminOrSupervisor()
        || (isSignedIn() && archivo.matches(request.auth.uid + '\\..*'));
      allow write: if isAdmin()
        || (isSignedIn() && archivo.matches(request.auth.uid + '\\..*'));
    }
    match /perfiles/{archivo} {
      allow read: if isAdminOrSupervisor()
        || (isSignedIn() && archivo.matches(request.auth.uid + '\\..*'));
      allow write: if isAdmin()
        || (isSignedIn() && archivo.matches(request.auth.uid + '\\..*'));
    }

    // ========================================================================
    // VEHICULOS — foto + comprobantes (RTO, Seguro, extintores)
    // ========================================================================

    match /vehiculos/{patente}/{archivo=**} {
      // Foto de la unidad — operativa, no PII. Chofer la ve en "Mi
      // equipo" para verificar que efectivamente es su unidad. Acceso
      // amplio aceptable.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    // Comprobantes (RTO, Seguro, extintores) — el código sube a VEHICULOS
    // en mayúsculas para distinguirlo de la carpeta de fotos (minúsculas).
    match /VEHICULOS/{patente}/{archivo=**} {
      // Papeles del vehiculo — admin/supervisor todos, chofer solo
      // los de SU unidad. Restriccion via lookup cross-namespace a
      // Firestore (auditoria 2026-05-17).
      allow read: if isAdminOrSupervisor()
        || (isSignedIn() &&
            firestore.exists(/databases/(default)/documents/EMPLEADOS/$(request.auth.uid)) &&
            (firestore.get(/databases/(default)/documents/EMPLEADOS/$(request.auth.uid)).data.VEHICULO == patente
             || firestore.get(/databases/(default)/documents/EMPLEADOS/$(request.auth.uid)).data.ENGANCHE == patente));
      allow write: if isAdmin();
    }

    // ========================================================================
    // EMPLEADOS — papeles del chofer reemplazados por admin
    // ========================================================================

    match /EMPLEADOS/{dni}/{archivo=**} {
      // Solo admin reemplaza papeles (sin pasar por el flujo de
      // revisión). El chofer NO escribe acá (lo hace en REVISIONES).
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == dni);
      allow write: if isAdmin();
    }

    // ========================================================================
    // EMPRESAS_EMPLEADORAS — Póliza ART y F.931 a nivel empresa
    // ========================================================================
    // Path: EMPRESAS_EMPLEADORAS/{cuit}/{archivo}
    // CRITICO (auditoria 2026-05-18): antes era `allow read: if isSignedIn()`,
    // dejando que CUALQUIER empleado bajara las pólizas ART, F.931 y SCVO
    // de TODAS las razones sociales (sueldos confidenciales en F.931, datos
    // de seguros). Ahora: admin/supervisor todos + solo empleados de la
    // misma razón social.
    match /EMPRESAS_EMPLEADORAS/{cuit}/{archivo=**} {
      allow read: if isAdminOrSupervisor() || isSegHigiene();
      allow write: if isAdmin();
    }

    // ========================================================================
    // EMPLEADOS_DOCS / VEHICULOS_DOCS — auditoría (sube al guardar)
    // ========================================================================
    // CRITICO (auditoria 2026-05-18): antes era `allow read: if isSignedIn()`,
    // permitiendo que CUALQUIER chofer adivine el nombre de archivo (el path
    // suele ser predecible: `{dni}_licencia_2026-03.pdf`) y baje PII grave
    // (DNI escaneado, foto del chofer, licencia, ART, RTO). Ahora restringido
    // a admin / supervisor / seg_higiene (los que gestionan vencimientos).

    match /EMPLEADOS_DOCS/{archivo=**} {
      allow read: if isAdminOrSupervisor() || isSegHigiene();
      allow write: if isAdmin();
    }
    match /VEHICULOS_DOCS/{archivo=**} {
      allow read: if isAdminOrSupervisor() || isSegHigiene();
      allow write: if isAdmin();
    }

    // ========================================================================
    // REVISIONES — el chofer sube comprobante al renovar un papel
    // ========================================================================

    match /REVISIONES/{archivo} {
      // CRITICO (auditoria 2026-05-18): antes era `allow read: if isSignedIn()`
      // — el path REVISIONES/{dni}_{campo}_{ts}.{ext} es predecible y dejaba
      // que un chofer adivinara nombres y bajara comprobantes (licencia,
      // psicofisico, DNI escaneado) de otros choferes. Ahora: admin/supervisor
      // todos + chofer SOLO los suyos (archivo arranca con su UID).
      allow read: if isAdminOrSupervisor()
        || (isSignedIn() && archivo.matches(request.auth.uid + '_.*'));
      // Cualquier signedIn (chofer) puede subir su comprobante.
      // El admin lo aprueba/rechaza desde la app.
      //
      // Validaciones del upload:
      //  - PREFIJO DEL ARCHIVO: tiene que empezar con `{uid}_` para que
      //    un chofer NO pueda sobrescribir comprobantes de otros choferes
      //    (el path real que arma revision_service es
      //    `REVISIONES/{dni}_{campo}_{ts}.{ext}` — cumple la regex).
      //    Admin/supervisor pueden subir con cualquier prefijo.
      //  - contentType: solo imagenes (image/*) o PDF. Antes admitia
      //    cualquier mimetype, lo que dejaba subir .exe enmascarados
      //    como .pdf u otros archivos raros que confunden al admin
      //    cuando los abre desde la pantalla de revisiones.
      //  - tamano <= 10 MB. Suficiente para PDFs y fotos HD; por
      //    encima de eso es ruido (videos, scanners no comprimidos).
      allow write: if isSignedIn()
        && (isAdminOrSupervisor() || archivo.matches(request.auth.uid + '_.*'))
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // ========================================================================
    // RemitosViaje — comprobantes firmados de remitos (módulo Logística)
    // ========================================================================
    // Path: RemitosViaje/{viajeId}_{ts}.{ext}
    // Lectura/escritura: admin + supervisor. NO se expone al chofer
    // (decisión Santiago 2026-05-09 — info delicada del módulo).
    // Validaciones del upload:
    //   - contentType: image/* o application/pdf.
    //   - tamaño ≤ 10 MB (mismo cap que REVISIONES).
    match /RemitosViaje/{archivo=**} {
      allow read: if isAdminOrSupervisor();
      allow write: if isAdminOrSupervisor()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // ========================================================================
    // FALLBACK — paths no listados quedan bloqueados
    // ========================================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
